{
  "name": "music-analyzer",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode client && vite build",
    "preview": "bun run build && bun run ./dist/index.js",
    "test": "bun test",
    "e2e:authentik": "RUN_AUTHENTIK_E2E=1 bun test e2e/authentik/flow.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun test",
    "db:generate": "DATABASE_URL=file:/dev/null prisma generate",
    "db:push": "prisma db push",
    "db:seed": "bun run prisma/seed.ts"
  },
  "dependencies": {
    "@hono/react-renderer": "^0.3.0",
    "@prisma/client": "^7",
    "hono": "^4.6.14",
    "honox": "^0.1.35",
    "prisma-adapter-bun-sqlite": "^0.7.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.1",
    "@types/bun": "^1.1.14",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "prisma": "^7",
    "testcontainers": "^11.14.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "packageManager": "bun@1.3.13",
  "trustedDependencies": [
    "@prisma/client",
    "@prisma/engines",
    "better-sqlite3",
    "cpu-features",
    "esbuild",
    "prisma",
    "protobufjs",
    "ssh2"
  ]
}
