{
  "name": "music-analyzer",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode client && vite build",
    "preview": "bun run build && bun run ./dist/index.js",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "bun run prisma/seed.ts"
  },
  "dependencies": {
    "@hono/react-renderer": "^0.3.0",
    "@prisma/client": "^5.22.0",
    "hono": "^4.6.14",
    "honox": "^0.1.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.1",
    "@types/bun": "^1.1.14",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "prisma": "^5.22.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
