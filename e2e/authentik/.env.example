# Copy to .env and edit before running `docker compose up`.
# For testing only — do NOT reuse these values in production.

# --- Postgres (used by authentik only) ---
PG_USER=authentik
PG_DB=authentik
PG_PASS=authentik-local-pass

# --- Authentik ---
# Generate a fresh key for real deployments:
#   openssl rand -base64 60 | tr -d '\n'
AUTHENTIK_SECRET_KEY=please-change-me-please-change-me-please-change-me

# akadmin credentials seeded on first boot.
AUTHENTIK_BOOTSTRAP_EMAIL=admin@localhost
AUTHENTIK_BOOTSTRAP_PASSWORD=changeme-admin
# API token for akadmin. Useful for programmatic e2e tests (testcontainers).
AUTHENTIK_BOOTSTRAP_TOKEN=changeme-token

# --- Ports ---
# Host interface published ports bind to. Defaults to loopback so the
# default akadmin credentials above don't end up reachable from the LAN.
# Set to 0.0.0.0 only when you intentionally need external access.
BIND_ADDR=127.0.0.1
CADDY_PORT_HTTP=8080
AUTHENTIK_PORT_HTTP=9000
AUTHENTIK_PORT_HTTPS=9443
